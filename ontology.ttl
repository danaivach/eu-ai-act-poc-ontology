:toy rdf:type owl:NamedIndividual ,
              :HighRiskSystemType ;
     rdfs:seeAlso <http://publications.europa.eu/resource/authority/fd_300/001391> .


###  http://example.org/ontologies/eu-ai-act/vulnerabilityExploitation
:vulnerabilityExploitation rdf:type owl:NamedIndividual ,
                                    <http://www.w3.org/2004/02/skos/core#Concept> ;
                           eli:refers_to <https://eur-lex.europa.eu/eli/reg/2024/1689/oj#art_5> ;
                           rdfs:comment "The exploitation of any of the vulnerabilities of a natural person or a specific group of persons due to their age, disability or a specific social or economic situation, with the objective, or the effect, of materially distorting the behaviour of that person or a person belonging to that group in a manner that causes or is reasonably likely to cause that person or another person significant harm."@en ;
                           rdfs:label "vulnerability exploitation"@en .


###  http://example.org/ontologies/eu-ai-act/vulnerabilityExploitationProhibition
:vulnerabilityExploitationProhibition rdf:type owl:NamedIndividual ,
                                               odrl:Prohibition ;
                                      eli:refers_to <https://eur-lex.europa.eu/eli/reg/2024/1689/oj#art_5> ;
                                      rdfs:comment "The prohibition of the placing on the market, the putting into service or the use of an AI system that exploits any of the vulnerabilities of a natural person or a specific group of persons due to their age, disability or a specific social or economic situation, with the objective, or the effect, of materially distorting the behaviour of that person or a person belonging to that group in a manner that causes or is reasonably likely to cause that person or another person significant harm."@en ;
                                      rdfs:label "vulnerability exploitation prohibition"@en .


