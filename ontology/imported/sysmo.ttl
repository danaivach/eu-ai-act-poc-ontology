sysmo:AlarmType
  rdf:type owl:Class ;
  dc:description "An \"Ordered Enumeration\" which is multi-modal with the following instance(s): \"Advisory alarm type\", \"Caution alarm type\", \"Emergency alarm type\", \"Warning alarm type\"."^^xsd:string ;
  rdfs:label "Alarm Type"^^xsd:string ;
  rdfs:subClassOf sysmo:EnumeratedValue ;
.
sysmo:AlarmTypeEnumeration
  rdf:type sysmo:Enumeration ;
  sysmo:auralCueEnumeration sysmo:AuralCueTypeEnumeration ;
  sysmo:visualCueEnumeration sysmo:AlarmColorEnumeration ;
  dtype:element sysmo:AT_ADVISORY ;
  dtype:element sysmo:AT_CAUTION ;
  dtype:element sysmo:AT_CHANGE ;
  dtype:element sysmo:AT_EMERGENCY ;
  dtype:element sysmo:AT_WARNING ;
  rdfs:label "Alarm Type Enumeration"^^xsd:string ;
.
sysmo:AlarmsSpecification
  rdf:type owl:Class ;
  rdfs:label "Alarms specification"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:AdvisoryAlarmLimitsPair ;
      owl:onProperty sysmo:hasAdvisoryAlarmLimits ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:AlarmLimitsPair ;
      owl:onProperty sysmo:hasAlarmLimitsPair ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:CautionAlarmLimitsPair ;
      owl:onProperty sysmo:hasCautionAlarmLimits ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:EmergencyAlarmLimitsPair ;
      owl:onProperty sysmo:hasEmergencyAlarmLimits ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:WarningAlarmLimitsPair ;
      owl:onProperty sysmo:hasWarningAlarmLimits ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:changeAlarm ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:hasAdvisoryAlarmLimits ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:hasCautionAlarmLimits ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:hasEmergencyAlarmLimits ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:hasWarningAlarmLimits ;
    ] ;
.
