sysmo:EmergencyAlarmLowLimit
  rdf:type owl:Class ;
  dc:description "A life threatening condition that requires immediate attention. Automated or predefined crew responses may be required before taking corrective action. Safe haven concept activation may be necessary. Included are the presence of fire and smoke, the presence of toxicity in the atmosphere, and the rapid loss of atmospheric pressure."^^xsd:string ;
  rdfs:label "Emergency alarm low limit"^^xsd:string ;
  rdfs:subClassOf sysmo:WarningAlarmLowLimit ;
.
sysmo:EncodedValueAlarmLimit
  rdf:type owl:Class ;
  rdfs:subClassOf sysmo:AlarmLimit ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysmo:EncodedValueType ;
      owl:onProperty sysmo:valueType ;
    ] ;
  owl:disjointWith sysmo:EngUnitAlarmLimit ;
  owl:equivalentClass [
      rdf:type owl:Class ;
      owl:intersectionOf (
          sysmo:AlarmLimit
          [
            rdf:type owl:Restriction ;
            owl:hasValue sysmo:EncodedValueType ;
            owl:onProperty sysmo:valueType ;
          ]
        ) ;
    ] ;
.
sysmo:EngUnitAlarmLimit
  rdf:type owl:Class ;
  rdfs:subClassOf sysmo:AlarmLimit ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:EngUnitsValue ;
      owl:onProperty sysmo:limitValue ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysmo:EngineeringUnitsType ;
      owl:onProperty sysmo:valueType ;
    ] ;
  owl:disjointWith sysmo:EncodedValueAlarmLimit ;
  owl:equivalentClass [
      rdf:type owl:Class ;
      owl:intersectionOf (
          sysmo:AlarmLimit
          [
            rdf:type owl:Restriction ;
            owl:hasValue sysmo:EngineeringUnitsType ;
            owl:onProperty sysmo:valueType ;
          ]
        ) ;
    ] ;
.
sysmo:Entity
  rdf:type owl:Class ;
  rdfs:label "Entity"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Feature ;
      owl:onProperty sysmo:hasFeature ;
    ] ;
.
sysmo:EnumeratedValue
  rdf:type owl:Class ;
  rdfs:label "System Enumerated Value"^^xsd:string ;
  rdfs:subClassOf sysmo:EnumeratedValue ;
  rdfs:subClassOf dtype:EnumeratedValue ;
.
sysmo:Enumeration
  rdf:type owl:Class ;
  rdfs:label "Enumeration"^^xsd:string ;
  rdfs:label "System Enumeration"^^xsd:string ;
  rdfs:subClassOf dtype:Enumeration ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:EnumeratedValue ;
      owl:onProperty sysmo:hasElement ;
    ] ;
.
sysmo:Event
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Event ;
      owl:onProperty sysmo:causes ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Event ;
      owl:onProperty sysmo:isCausedBy ;
    ] ;
.
sysmo:Facility
  rdf:type owl:Class ;
  dc:description "A kind of \"System\"."^^xsd:string ;
  rdfs:label "Facility"^^xsd:string ;
  rdfs:subClassOf sysmo:System ;
.
sysmo:Failure
  rdf:type owl:Class ;
  dc:description "A failure is a malfunction of some device, subsystem, system or element."^^xsd:string ;
  rdfs:label "Failure"^^xsd:string ;
  rdfs:subClassOf sysmo:UnIntendedBehavior ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Cause ;
      owl:onProperty sysmo:isCausedBy ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Effect ;
      owl:onProperty sysmo:hasEffect ;
    ] ;
.
sysmo:FailureCriticality
  rdf:type owl:Class ;
  dc:description """1 - Single failure that could result in loss of life or vehicle.
2 - Single failure that could result in a loss of mission.
1R# - Redundant hardware item, which if all failed, could cause loss of life or vehicle. A number is used to indicate the number of redundant paths or strings (e.g. 1R3 - a triple redundant item).
1S - Failure in a safety or hazard monitoring hardware item that could cause the system to fail to detect, combat, or operate when needed during a hazardous condition, potentially resulting in loss of life or vehicle. 
2R - Redundant hardware item, which if all failed, could cause a loss of mission.
3 - All other failures."""^^xsd:string ;
  dc:description "Criticality is defined in terms of the following levels of severity: Safety Critical, Mission Critical, Loss of Functionality."^^xsd:string ;
  rdfs:label "Failure criticality"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:CatastrophicLoss ;
      owl:onProperty sysmo:hasPossibleConsequence ;
    ] ;
.
sysmo:Feature
  rdf:type owl:Class ;
  rdfs:comment "The NASA use of feature is consistent with the NIST definition of feature: a feature is a subset of the form of an artifact that has some function associated with it. An artifact may have design features, analysis features, manufacturing features, interface features (sometimes referred to as ports) as determined by their respective functions (NISTIR 6736)."^^xsd:string ;
  rdfs:label "Feature"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Component ;
      owl:onProperty sysmo:hasComponent ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Device ;
      owl:onProperty sysmo:hasDevice ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
      owl:onProperty sysmo:hasSubsystem ;
    ] ;
.
sysmo:FlightIntent
  rdf:type owl:Class ;
  dc:description "A kind of \"Intent\"."^^xsd:string ;
  rdfs:label "Flight Intent"^^xsd:string ;
  rdfs:subClassOf sysmo:Intent ;
  owl:disjointWith sysmo:NonflightIntent ;
.
sysmo:FlowDirectionEnumeration
  rdf:type sysmo:EnumerationType ;
  sysmo:element sysml:InFlow ;
  sysmo:element sysml:InOutFlow ;
  sysmo:element sysml:OutFlow ;
  rdfs:label "Flow direction enumeration"^^xsd:string ;
.
sysmo:FlowSpecification
  rdf:type owl:Class ;
  dc:description "A FlowSpecification specifies inputs and outputs as a set of flow properties. A flow specification is used by Flow Ports to specify what flow items can flow via the port." ;
  rdfs:label "Flow Specification"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:FlowProperty ;
      owl:onProperty sysmo:hasInput ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:FlowProperty ;
      owl:onProperty sysmo:hasOutput ;
    ] ;
.
sysmo:Form
  rdf:type owl:Class ;
  rdfs:label "Form"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Entity ;
    ] ;
.
sysmo:FullyFunctionalCondition
  rdf:type owl:Class ;
  dc:description "A kind of \"Condition\"."^^xsd:string ;
  rdfs:label "Fully Functional Condition"^^xsd:string ;
  rdfs:subClassOf sysmo:Condition ;
  owl:disjointWith sysmo:NonFunctionalCondition ;
  owl:disjointWith sysmo:PartiallyFunctionalCondition ;
.
sysmo:Function
  rdf:type owl:Class ;
  rdfs:label "Function"^^xsd:string ;
  rdfs:subClassOf sysmo:IdentifiableConcept ;
