sysmo:PLT_EXCLUSIVE
  rdf:type sysmo:ParameterLimitType ;
  dc:description "If the Limit Type is Exclusive, then any value between the Low Limit and High Limit is considered unacceptable. Values below the Low Limit or above the High Limit would be considered valid." ;
  dtype:code 1 ;
  dtype:value "exclusive"^^xsd:string ;
  rdfs:label "Exclusive limit type"^^xsd:string ;
.
sysmo:PLT_INCLUSIVE
  rdf:type sysmo:ParameterLimitType ;
  dc:description "If the Limit Type is Inclusive, then any value between the Low Limit and High Limit is considered acceptable. Values below the Low Limit or above the High Limit would be considered invalid." ;
  dtype:code 2 ;
  dtype:value "inclusive"^^xsd:string ;
  rdfs:label "Inclusive limit type"^^xsd:string ;
.
sysmo:Parameter
  rdf:type owl:Class ;
  dc:description "A measured or controlled parameter of some sensor or effector within a system hierarchy" ;
  rdfs:label "Parameter"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
      owl:onProperty sysmo:isParameterOf ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:controllableParameter ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasLocation ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasPropertyType ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasConfidentiality ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:occurence ;
    ] ;
.
sysmo:ParameterLimitType
  rdf:type owl:Class ;
  dc:description "An enumeration with the following instance(s): \"Exclusive limit type\", \"Inclusive limit type\"."^^xsd:string ;
  rdfs:label "Parameter Limit Type"^^xsd:string ;
  rdfs:subClassOf sysmo:EnumeratedValue ;
.
sysmo:ParameterLimitTypeEnumeration
  rdf:type owl:Class ;
  sysmo:default sysmo:PLT_INCLUSIVE ;
  sysmo:element sysmo:PLT_EXCLUSIVE ;
  sysmo:element sysmo:PLT_INCLUSIVE ;
  rdfs:label "Parameter limit type enumeration"^^xsd:string ;
  rdfs:subClassOf sysmo:Enumeration ;
.
sysmo:ParameterLimits
  rdf:type owl:Class ;
  sysmo:description "'Parameter Limits' is a specification of low and high limits for a parameter that are applicable in a given system mode or condition."^^xsd:string ;
  rdfs:label "Parameter Limits"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      dc:description "The high limit value for a parameter.  The Limit Type specifies whether High Limit is considered to be the highest allowed or disallowed value. The value may be calibrated or uncalibrated (see Calibrated Limits attribute). The encoded form of the provided value must be consistent with the Data Type and Parameter Length specified for the parameter, as defined in this table. Value is undefined for predefined parameters and optional for modifiable parameters. If provided the value must be greater than the Low Limit." ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:parameterHighLimit ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      dc:description "The low limit value for a parameter.  The Limit Type specifies whether Low Limit is considered to be the lowest allowed or disallowed value. The value may be calibrated or uncalibrated (see Calibrated Limits attribute). The encoded form of the provided value must be consistent with the Data Type and Parameter Length specified for the parameter, as defined in this table. Value is undefined for predefined parameters and optional for modifiable parameters. If provided the value must be less than the High Limit." ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:parameterLowLimit ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      sysmo:default "false"^^xsd:boolean ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:encodedValueLimits ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Condition ;
      owl:onProperty sysmo:inCondition ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:ControlledParameter ;
      owl:onProperty sysmo:hasParameterLimitsFor ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:LimitType ;
      owl:onProperty sysmo:hasParameterLimitType ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Mode ;
      owl:onProperty sysmo:inMode ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasParameterLimitType ;
    ] ;
.
