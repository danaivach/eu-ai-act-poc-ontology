sysmo:Mode
  rdf:type owl:Class ;
  dc:description "An enumeration with the following elements: \"Anomaly mode\", \"Cold start mode\", \"Degraded mode\", \"Failed mode\", \"Hot start mode\", \"Normal mode\", \"Recon mode\", \"Recovery mode\", \"Safed mode\", \"Shut down mode\", \"Standby mode\", \"Test mode\", \"Warm start mode\"."^^xsd:string ;
  rdfs:label "Mode"^^xsd:string ;
  rdfs:subClassOf sysmo:EnumeratedValue ;
.
sysmo:Model
  rdf:type owl:Class ;
  dc:description "A kind of \"Model\"."^^xsd:string ;
  rdfs:label "Model"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
.
