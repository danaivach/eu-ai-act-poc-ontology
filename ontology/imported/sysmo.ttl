.
sysmo:Vehicle
  rdf:type owl:Class ;
  rdfs:subClassOf sysmo:Element ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:VehicleCompartment ;
      owl:onProperty sysmo:hasPart ;
