    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty <http://www.sysmo.org/ontologies/sysmo.owl#tolerancePressureMax> ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty <http://www.sysmo.org/ontologies/sysmo.owl#tolerancePressureMin> ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty <http://www.sysmo.org/ontologies/sysmo.owl#toleranceTemperatureMax> ;
    ] ;
