sysmo:dwellTime
  rdf:type owl:DatatypeProperty ;
  dc:description "An abstract property for the time (in seconds expressed as double precision floating point) that the condition needs to persist before a caution alarm is generated. During this period, the dynamic process remains halted so that another process may occur." ;
  dtype:abstract "true"^^xsd:boolean ;
  rdfs:label "dwell time"^^xsd:string ;
  rdfs:range xsd:double ;
.
