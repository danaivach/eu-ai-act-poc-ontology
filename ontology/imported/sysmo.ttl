    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Mode ;
      owl:onProperty sysmo:hasCurrentMode ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Mode ;
      owl:onProperty sysmo:hasMode ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Mode ;
      owl:onProperty sysmo:hasMode ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Module ;
      owl:onProperty sysmo:hasModule ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:NonFunctionalRequirement ;
      owl:onProperty sysmo:hasNonFunctionalRequirement ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Operation ;
      owl:onProperty sysmo:hasOperation ;
