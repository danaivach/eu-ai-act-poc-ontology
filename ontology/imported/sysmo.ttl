sysmo:CautionAlarm
  rdf:type owl:Class ;
  dc:description "Conditions that are less time-critical but have the potential for further degradation if crew attention is not given. Included are faults, failures, and out of tolerance conditions for functions critical to mission success."^^xsd:string ;
  rdfs:label "Caution alarm"^^xsd:string ;
  rdfs:subClassOf sysmo:Alarm ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysmo:AT_CAUTION ;
      owl:onProperty sysmo:hasAlarmType ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue "2"^^xsd:int ;
      owl:onProperty dtype:code ;
    ] ;
  owl:equivalentClass [
      rdf:type owl:Class ;
      owl:intersectionOf (
          sysmo:Alarm
          [
            rdf:type owl:Restriction ;
            owl:hasValue sysmo:AT_CAUTION ;
            owl:onProperty sysmo:hasAlarmType ;
          ]
        ) ;
    ] ;
.
sysmo:CautionAlarmLimitsPair
  rdf:type owl:Class ;
