  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Calibrator ;
      owl:onProperty sysmo:calibrator ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom <http://www.sysmo.org/ontologies/assembly.owl#MountingTechnique> ;
