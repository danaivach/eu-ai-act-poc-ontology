      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:hasSpecification ;
    ] ;
.
sysmo:MeasurementSpecification
  rdf:type owl:Class ;
