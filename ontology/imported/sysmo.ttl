sysmo:hasCautionAlarmHighLimit
  rdf:type owl:ObjectProperty ;
  dc:description "If the parameter's value is greater than or equal to the Caution High Limit and less that the Warning High Limit, then a Caution Alarm violation occurs. If the parameterâ€™s value is greater than or equal to the Warning High Limit, then a Warning Alarm Violation occurs." ;
  rdfs:label "caution alarm high limit"^^xsd:string ;
  rdfs:subPropertyOf sysmo:advisoryAlarmHighLimit ;
  rdfs:subPropertyOf sysmo:hasAdvisoryAlarmHighLimit ;
.
