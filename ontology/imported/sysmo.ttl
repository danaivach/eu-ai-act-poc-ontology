  rdfs:subClassOf sysmo:Enumeration ;
.
sysmo:NestedConnectorEnd
  rdf:type owl:Class ;
  dc:description "The NestedConnectorEnd is a kind of ConnectorEnd for which the connected property may be identified by a multi-level path of accessible properties from the block that owns the connector." ;
  rdfs:label "Nested Connector End"^^xsd:string ;
  rdfs:subClassOf sysmo:ConnectorEnd ;
.
sysmo:NonCalibratedParameter
  rdf:type owl:Class ;
  dc:description "A kind of \"Observed Property\"."^^xsd:string ;
  rdfs:label "Non Calibrated Parameter"^^xsd:string ;
  rdfs:subClassOf sysmo:MeasuredParameter ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "0"^^xsd:int ;
      owl:onProperty sysmo:calibrationType ;
    ] ;
  owl:disjointWith sysmo:CalibratedParameter ;
.
sysmo:NonControlledParameter
  rdf:type owl:Class ;
  dc:description "A \"Parameter\" that is not controlled."^^xsd:string ;
  rdfs:label "Non-controlled Parameter"^^xsd:string ;
  rdfs:subClassOf sysmo:Parameter ;
  owl:disjointWith sysmo:ControlledParameter ;
.
sysmo:NonFunctionalCondition
  rdf:type owl:Class ;
  dc:description "A kind of \"Condition\"."^^xsd:string ;
  rdfs:label "Non Functional Condition"^^xsd:string ;
  rdfs:subClassOf sysmo:Condition ;
  owl:disjointWith sysmo:FullyFunctionalCondition ;
  owl:disjointWith sysmo:PartiallyFunctionalCondition ;
.
sysmo:NonFunctionalRequirement
  rdf:type owl:Class ;
  rdfs:label "Non functional requirement"^^xsd:string ;
  rdfs:subClassOf sysml:Requirement ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty dc:source ;
    ] ;
