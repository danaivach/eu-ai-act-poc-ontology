  rdfs:subPropertyOf sysmo:hasAlarmLimitsPair ;
.
sysmo:hasCautionAlarmLowLimit
  rdf:type owl:ObjectProperty ;
  dc:description "If a parameter's value is less than or equal to the Caution Low Limit and greater than the Warning Low Limit, then a Caution Alarm Violation occurs. If the parameterâ€™s value is less than or equal to the Warning Low Limit, then a Warning Alarm violation occurs." ;
  rdfs:label "caution alarm low limit"^^xsd:string ;
  rdfs:subPropertyOf sysmo:advisoryAlarmLowLimit ;
  rdfs:subPropertyOf sysmo:hasAdvisoryAlarmLowLimit ;
.
sysmo:hasCautionMonitor
  rdf:type owl:ObjectProperty ;
  rdfs:label "caution monitor"^^xsd:string ;
  rdfs:range sysmo:CautionAlarmLimitsSpecification ;
