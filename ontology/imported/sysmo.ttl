sysmo:BehaviorFeature
  rdf:type owl:Class ;
  dc:description "A block that describes an aspect of behavior."^^xsd:string ;
  rdfs:label "Behavior Feature"^^xsd:string ;
  rdfs:subClassOf sysml:Block ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
      owl:onProperty sysmo:isFeatureOf ;
    ] ;
.
sysmo:BindingConnector
  rdf:type owl:Class ;
  dc:description "A Binding Connector is a connector which specifies that the properties at both ends of the connector have equal values. If the properties at the ends of a binding connector are typed by a DataType or ValueType, the connector specifies that the instances of the properties must hold equal values, recursively through any nested properties within the connected properties. If the properties at the ends of a binding connector are typed by a Block, the connector specifies that the instances of the properties must refer to the same block instance." ;
  rdfs:label "Binding Connector"^^xsd:string ;
  rdfs:subClassOf sysmo:Connector ;
.
sysmo:BoundarySystem
  rdf:type owl:Class ;
  dc:description "A Boundary system is a special external system that serves as medium between another system and the system under development without having own interests in the communication. For example Bus system or Communication system."^^xsd:string ;
  rdfs:label "Boundary system"^^xsd:string ;
  rdfs:subClassOf sysmo:System ;
.
sysmo:CL_LOSS-OF-CREW
  rdf:type sysmo:CatastrophicLoss ;
  rdfs:label "Loss of crew"^^xsd:string ;
.
sysmo:CL_LOSS-OF-MISSION
