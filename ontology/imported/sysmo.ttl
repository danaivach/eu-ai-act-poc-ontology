sysmo:System
  rdf:type owl:Class ;
  dc:description "A system is defined as a viable entity that has structure, behavior, functionality and interaction with other systems so as to provide capabilities that satisfy some objective criteria in the presence of constraints.  This model of system, called an SBFI model, is used to characterize all constellation systems irrespective ranging in scope from ground support equipment, vehicles, their systems and subsystems, to components and devices."^^xsd:string ;
  rdfs:label "System"^^xsd:string ;
  rdfs:subClassOf sysmo:Element ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Block ;
      owl:onProperty sysmo:includes ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Assembly ;
      owl:onProperty sysmo:hasAssembly ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:BehaviorFeature ;
      owl:onProperty sysmo:hasBehaviorFeature ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Capability ;
      owl:onProperty sysmo:hasCapability ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Command ;
      owl:onProperty sysmo:hasCommand ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Component ;
      owl:onProperty sysmo:hasComponent ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Condition ;
      owl:onProperty sysmo:hasCondition ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Condition ;
      owl:onProperty sysmo:hasCurrentCondition ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:ConstraintsSet ;
      owl:onProperty sysmo:hasConstraintSet ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Device ;
      owl:onProperty sysmo:hasDevice ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Function ;
      owl:onProperty sysmo:hasFunction ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:FunctionFeature ;
      owl:onProperty sysmo:hasFunctionalFeature ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
