# baseURI: http://sysmo.org/1.0/schema/sysmo
# imports: http://www.linkedmodel.org/schema/dtype
# imports: http://www.linkedmodel.org/schema/vaem

@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dtype: <http://www.linkedmodel.org/schema/dtype#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sysml: <http://sysmo.org/schema/sysml/> .
@prefix sysmo: <http://sysmo.org/schema/sysmo/> .
@prefix vaem: <http://www.linkedmodel.org/schema/vaem#> .
@prefix voag: <http://voag.linkedmodel.org/schema/voag#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dc:author
  rdf:type owl:AnnotationProperty ;
  rdfs:label "author"^^xsd:string ;
  rdfs:range xsd:string ;
.
dc:contributor
  rdf:type owl:AnnotationProperty ;
  rdfs:label "contributor"^^xsd:string ;
  rdfs:range xsd:string ;
.
dc:creator
  rdf:type owl:AnnotationProperty ;
  rdfs:label "creator"^^xsd:string ;
  rdfs:range xsd:string ;
.
dc:date
  rdf:type owl:AnnotationProperty ;
  rdfs:label "date"^^xsd:datetime ;
  rdfs:range xsd:dateTime ;
.
dc:description
  rdf:type owl:AnnotationProperty ;
  rdfs:label "description"^^xsd:string ;
  rdfs:range xsd:string ;
.
dc:rights
  rdf:type owl:AnnotationProperty ;
  rdfs:label "rights"^^xsd:string ;
  rdfs:range xsd:string ;
.
dc:subject
  rdf:type owl:AnnotationProperty ;
  rdfs:label "subject"^^xsd:string ;
  rdfs:range xsd:string ;
.
dc:title
  rdf:type owl:AnnotationProperty ;
  rdfs:label "title"^^xsd:string ;
  rdfs:range xsd:string ;
.
<http://sysmo.org/1.0/schema/sysmo>
  rdf:type owl:Ontology ;
  dc:creator "Ralph Hodgson"^^xsd:string ;
  dc:description "The SysMO ontology defines classes, individuals and properties, under the \"sysmo\" namespace, that are relevant to systems. The SysMO ontology is intended to be used to (a) represent SysML resources; (b) serve as a foundation for other system engineering ontologies; (c) provide a basis for linking to ISO-15926 and CIM models.  Release 1.0 of SysMO represents constructs from version 1.2 of SysML."^^xsd:string ;
  dc:subject "Systems"^^xsd:string ;
  dc:title "SysMO Release 1 Ontology"^^xsd:string ;
  vaem:dateCreated "2008-06-15"^^xsd:date ;
  vaem:hasGraphRole vaem:MappingGraph ;
  vaem:hasLicenseType voag:CC-SHAREALIKE_3PT0-US ;
  vaem:lastUpdated "2014-06-21"^^xsd:date ;
  vaem:namespace "http://sysmo.org/schema/sysmo/"^^xsd:anyURI ;
  vaem:namespacePrefix "sysmo"^^xsd:string ;
  vaem:owner "Ralph Hodgson, TopQuadrant"^^xsd:string ;
  vaem:usesNonImportedResource dc:author ;
  vaem:usesNonImportedResource dc:contributor ;
  vaem:usesNonImportedResource dc:creator ;
  vaem:usesNonImportedResource dc:date ;
  vaem:usesNonImportedResource dc:description ;
  vaem:usesNonImportedResource dc:rights ;
  vaem:usesNonImportedResource dc:subject ;
  vaem:usesNonImportedResource dc:title ;
  vaem:usesNonImportedResource voag:CC-SHAREALIKE_3PT0-US ;
  vaem:usesNonImportedResource voag:TopQuadrantAttribution ;
  vaem:usesNonImportedResource prov:wasInfluencedBy ;
  vaem:withAttributionTo voag:TopQuadrantAttribution ;
  rdfs:label "SysMO Ontology"^^xsd:string ;
  owl:imports <http://www.linkedmodel.org/schema/dtype> ;
  owl:imports <http://www.linkedmodel.org/schema/vaem> ;
  owl:versionInfo "Created with TopBraid Composer"^^xsd:string ;
.
sysml:AnalysisVerificationKind
  rdf:type sysml:VerificationKind ;
  dc:description "Analysis indicates that verification will be performed by technical evaluation using mathematical representations, charts, graphs, circuit diagrams, data reduction, or representative data. Analysis also includes the verification of requirements under conditions, which are simulated or modeled; where the results are derived from the analysis of the results produced by the model."^^xsd:string ;
  dtype:value "analysis"^^xsd:string ;
  rdfs:label "Analysis verification kind"^^xsd:string ;
.
sysml:AtomicFlowPort
  rdf:type owl:Class ;
  dc:description "A kind of \"Flow Port\"."^^xsd:string ;
  rdfs:label "Atomic Flow Port"^^xsd:string ;
  rdfs:subClassOf sysml:FlowPort ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "0"^^xsd:int ;
      owl:onProperty sysmo:hasFlowSpecification ;
    ] ;
  owl:disjointWith sysml:NonAtomicFlowPort ;
.
sysml:Block
  rdf:type owl:Class ;
  dc:description "A Block is a modular unit that describes some aspect of a system or element. It may include both structural and behavioral features, such as properties and operations, that represent the state of the system and behavior that the system may exhibit. Some of these properties may hold parts of a system, which can also be described by blocks. A block may include a structure of connectors between its properties to indicate how its parts or other properties relate to one another. Blocks provide a general-purpose capability to describe the architecture of a system. They provide the ability to represent a system hierarchy, in which a system at one level is composed of systems at a more basic level. They can describe not only the connectivity relationships between the systems at any level, but also quantitative values or other information about a system." ;
  rdfs:label "Block"^^xsd:string ;
  rdfs:subClassOf sysml:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      dc:description "If true, then the block is treated as a black box; a part typed by this black box can only be connected via its ports or directly to its outer boundary. If false, then connections can be established to elements of its internal structure via deep-nested connector ends." ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysml:isEncapsulated ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Block ;
      owl:onProperty sysml:hasBlock ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Block ;
      owl:onProperty sysml:isBlockOf ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:FlowPort ;
      owl:onProperty sysmo:hasFlowPort ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:FlowProperty ;
      owl:onProperty sysmo:hasFlowProperty ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:InteractionPort ;
      owl:onProperty sysmo:hasInteractionPort ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Port ;
      owl:onProperty sysmo:hasPort ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Connector ;
      owl:onProperty sysmo:hasConnector ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
      owl:onProperty sysmo:includes ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
      owl:onProperty sysmo:isIncludedIn ;
    ] ;
.
sysml:BusinessRequirement
  rdf:type owl:Class ;
  rdfs:label "Business requirement"^^xsd:string ;
  rdfs:subClassOf sysml:Requirement ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:VerificationKind ;
      owl:onProperty sysmo:hasVerifyMethodKind ;
    ] ;
.
sysml:ConnectorProperty
  rdf:type owl:Class ;
  dc:description "These connectors specify instances (links) of the association block that exist due to instantiation of the block owning or inheriting the connector. The value of a connector property on an instance of a block will be exactly those link objects that are instances of the association block typing the connector referred to by the connector property. A connector property can optionally be shown in an internal block diagram with a dotted line from the connector line to a rectangle notating the connector property. The keyword \"connector\" before a property name indicates the property is a ConnectorProperty." ;
  rdfs:label "Connector property"^^xsd:string ;
  rdfs:subClassOf sysml:Property ;
.
sysml:ConstraintProperty
  rdf:type owl:Class ;
  dc:description "A constraint property is a property of any block that is typed by a constraint block. It holds a localized usage of the constraint block. Binding connectors may be used to bind the parameters of this constraint block to other properties of the block that contains the usage." ;
  rdfs:label "Constraint Property"^^xsd:string ;
  rdfs:subClassOf sysml:Property ;
.
sysml:ControlValue
  rdf:type owl:Class ;
  dc:description "The ControlValue enumeration is a type for treating control values as data and for UML control pins. It can be used as the type of behavior and operation parameters, object nodes, and attributes, and so on. The possible runtime values are given as enumeration literals. Modelers can extend the enumeration with additional literals, such as suspend, resume, with their own semantics."^^xsd:string ;
  rdfs:label "Control value"^^xsd:string ;
  rdfs:subClassOf sysml:EnumeratedValue ;
.
sysml:ControlValueEnumeration
  rdf:type sysml:Enumeration ;
  sysmo:element sysml:Disable ;
  sysmo:element sysml:Enable ;
  rdfs:label "Control value enumeration"^^xsd:string ;
.
sysml:DataFlowPort
  rdf:type owl:Class ;
  dc:description "A kind of \"Flow Port\"."^^xsd:string ;
  rdfs:label "Data Flow Port"^^xsd:string ;
  rdfs:subClassOf sysml:FlowPort ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Quantity ;
      owl:onProperty sysmo:hasExportedData ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Quantity ;
      owl:onProperty sysmo:hasImportedData ;
    ] ;
.
sysml:DemonstrationVerificationKind
  rdf:type sysml:VerificationKind ;
  dc:description "Demonstration indicates that verification will be performed by operation, movement or adjustment of the item under specific conditions to perform the design functions without recording of quantitative data. Demonstration is typically considered the least restrictive of the verification types."^^xsd:string ;
  dtype:value "demonstration"^^xsd:string ;
  rdfs:label "Demonstration verification kind"^^xsd:string ;
.
sysml:Disable
  rdf:type sysml:ControlValue ;
  rdfs:label "Disable"^^xsd:string ;
.
sysml:DistributedProperty
  rdf:type owl:Class ;
  dc:description "A DistributedProperty is a kind of BlockProperty used to apply a probability distribution to the values of the property. Specific distributions should be defined as subclasses of the DistributedProperty with the operands of the distributions represented by properties of those subclasses." ;
  rdfs:label "Distributed Property"^^xsd:string ;
  rdfs:subClassOf sysml:Property ;
.
sysml:Enable
  rdf:type sysml:ControlValue ;
  dtype:value "enable"^^xsd:string ;
  rdfs:label "Enable"^^xsd:string ;
.
sysml:EnumeratedValue
  rdf:type owl:Class ;
  rdfs:label "Enumeration element"^^xsd:string ;
  rdfs:subClassOf dtype:EnumeratedValue ;
.
sysml:Enumeration
  rdf:type owl:Class ;
  rdfs:label "Enumeration"^^xsd:string ;
  rdfs:subClassOf dtype:Enumeration ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:EnumeratedValue ;
      owl:onProperty sysmo:hasElement ;
    ] ;
.
sysml:ErrorVerdict
  rdf:type sysml:VerdictKind ;
  dtype:value "error"^^xsd:string ;
  rdfs:label "Error verdict"^^xsd:string ;
.
sysml:FailVerdict
  rdf:type sysml:VerdictKind ;
  dtype:value "fail"^^xsd:string ;
  rdfs:label "Fail verdict"^^xsd:string ;
.
sysml:FlowDirection
  rdf:type owl:Class ;
  dc:description "FlowDirection, as defined in SysML, is an enumeration type that defines literals used for specifying input and output directions. FlowDirection is used by FlowProperties to indicate if the property is an input or an output with respect to its owner." ;
  rdfs:label "Flow Direction"^^xsd:string ;
  rdfs:subClassOf sysml:EnumeratedValue ;
.
sysml:FlowPort
  rdf:type owl:Class ;
  dc:description "Flow Ports are interaction points through which input and/or output of items such as data, material or some property such as torque, pressure or energy may flow. This enables the owning block to declare which items it may exchange with its environment and what are the interaction points through which the exchange is made. A FlowPort specifies the input and output items that may flow between a Block and its environment. FlowPorts are interaction points through which data, material or energy  'can' enter or leave the owning Block. The specification of what can flow is achieved by typing the FlowPort with a specification of things that flow. In general, flow ports are intended to be used for asynchronous, broadcast, or send and forget interactions." ;
  rdfs:label "Flow Port"^^xsd:string ;
  rdfs:subClassOf sysml:Port ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      dc:description "Indicates the direction in which an Atomic FlowPort relays its items. If the direction is set to in then the items are relayed from an external connector via the FlowPort into the FlowPort's owner (or one of its Parts). If the direction is set to out, then the items are relayed from the FlowPort's owner, via the FlowPort, through an external connector attached to the FlowPort, and if the direction is set to inout then items can flow both ways. By default, the value is inout." ;
      owl:allValuesFrom sysml:FlowDirection ;
      owl:onProperty sysmo:hasDirection ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:InOutFlowProperty ;
      owl:onProperty sysmo:hasBidirectionalFlow ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Connector ;
      owl:onProperty sysmo:isSinkFor ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Connector ;
      owl:onProperty sysmo:isSourceFor ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:FlowSpecification ;
      owl:onProperty sysmo:hasFlowSpecification ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasDirection ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasFlowSpecification ;
    ] ;
.
sysml:FlowProperty
  rdf:type owl:Class ;
  dc:description "A FlowProperty signifies a single flow element to/from a Block. A FlowProperty is a Property such as temperature, pressure or torque, with a direction prefix (in | out | inout)." ;
  rdfs:label "Flow Property"^^xsd:string ;
  rdfs:subClassOf sysml:Property ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      dc:description "Specifies if the property value is received from an external Block (direction=in), transmitted to an external Block (direction=out) or both (direction=inout)." ;
      owl:allValuesFrom sysml:FlowDirection ;
      owl:onProperty sysmo:hasDirection ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasDirection ;
    ] ;
.
sysml:FunctionalRequirement
  rdf:type owl:Class ;
  rdfs:label "Functional requirement"^^xsd:string ;
  rdfs:subClassOf sysml:Requirement ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:VerificationKind ;
      owl:onProperty sysmo:hasVerifyMethodKind ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty dc:source ;
    ] ;
.
sysml:HighRisk
  rdf:type sysml:RiskKind ;
  dtype:code 3 ;
  dtype:order "3"^^xsd:nonNegativeInteger ;
  dtype:value "high"^^xsd:string ;
  rdfs:label "High risk"^^xsd:string ;
.
sysml:InFlow
  rdf:type sysml:FlowDirection ;
  dc:description "Indicates that the flow property is input to the owning Block." ;
  dtype:code 1 ;
  dtype:value "in"^^xsd:string ;
  rdfs:label "In flow"^^xsd:string ;
.
sysml:InOutFlow
  rdf:type sysml:FlowDirection ;
  dc:description "Indicates that the flow property is both an input and an output of the owning Block." ;
  dtype:code 3 ;
  dtype:value "inout"^^xsd:string ;
  rdfs:label "Out Flow"^^xsd:string ;
.
sysml:InOutFlowProperty
  rdf:type owl:Class ;
  dc:description "A kind of \"Flow Property\"."^^xsd:string ;
  rdfs:label "In Out Flow Property"^^xsd:string ;
  rdfs:subClassOf sysml:FlowProperty ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysml:InFlow ;
      owl:onProperty sysmo:hasDirection ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysml:OutFlow ;
      owl:onProperty sysmo:hasDirection ;
    ] ;
.
sysml:InboundFlowProperty
  rdf:type owl:Class ;
  dc:description "A kind of \"Flow Property\"."^^xsd:string ;
  rdfs:label "Inbound Flow Property"^^xsd:string ;
  rdfs:subClassOf sysml:FlowProperty ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysml:InFlow ;
      owl:onProperty sysmo:hasDirection ;
    ] ;
  owl:disjointWith sysml:OutboundFlowProperty ;
.
sysml:InconclusiveVerdict
  rdf:type sysml:VerdictKind ;
  dtype:value "inconclusive"^^xsd:string ;
  rdfs:label "Inconclusive verdict"^^xsd:string ;
.
sysml:InspectionVerificationKind
  rdf:type sysml:VerificationKind ;
  dc:description "Inspection indicates that verification will be performed by examination of the item, reviewing descriptive documentation, and comparing the appropriate characteristics with a predetermined standard to determine conformance to requirements without the use of special laboratory equipment or procedures."^^xsd:string ;
  dtype:value "inspection"^^xsd:string ;
  rdfs:label "Inspection verification kind"^^xsd:string ;
.
sysml:InteractionPort
  rdf:type owl:Class ;
  dc:description "An 'Interaction Port' corresponds to a SysML 'Standard Port'. This specifies the services the owning Block provides (offers) to its environment as well as the services that the owning Block expects (requires) of its environment. The specification of the services is achieved by typing the Standard Port by the provided and/or required interfaces. In general Standard Ports are used in the context of serviceoriented architectures, which is typical for software component architectures. Since standard ports contain operations which specify bi-directional flow of data, standard ports are typically used in the context of peer-to-peer synchronous request/reply communications. A special case of a service is signal reception, which signifies a one way communication of signal instances, where the handling of the request is asynchronous. For example, a Block representing an automatic transmission in a car could have a Standard Port that specifies that the Transmission Block can accept commands to switch gears." ;
  rdfs:label "Standard Port"^^xsd:string ;
  rdfs:subClassOf sysml:Port ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:ProvidedInterface ;
      owl:onProperty sysmo:providesService ;
    ] ;
.
sysml:LowRisk
  rdf:type sysml:RiskKind ;
  dtype:code 1 ;
  dtype:order "1"^^xsd:nonNegativeInteger ;
  dtype:value "low"^^xsd:string ;
  rdfs:label "Low risk"^^xsd:string ;
.
sysml:MediumRisk
  rdf:type sysml:RiskKind ;
  dtype:code 2 ;
  dtype:order "2"^^xsd:nonNegativeInteger ;
  dtype:value "medium"^^xsd:string ;
  rdfs:label "Medium risk"^^xsd:string ;
.
sysml:NonAtomicFlowPort
  rdf:type owl:Class ;
  dc:description "A kind of \"Flow Port\"."^^xsd:string ;
  rdfs:label "Non Atomic Flow Port"^^xsd:string ;
  rdfs:subClassOf sysml:FlowPort ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      dc:description "Indicates if the flow of items of a non-atomic flow port maintain the directions specified in the FlowSpecification or the direction of every flow property specified in the FlowSpecification is reversed (IN becomes OUT and vice versa). If set to True then all the directions of the FlowProperties specified by the FlowSpecification that types a Non-Atomic FlowPort are relayed in the opposite direction (i.e., in flow property is treated as an out flow property by the FlowPort and vice-versa). By default, the value is False." ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:conjugated ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasFlowSpecification ;
    ] ;
.
sysml:OperationsBlock
  rdf:type owl:Class ;
  rdfs:label "Operations block"^^xsd:string ;
  rdfs:subClassOf sysmo:FunctionFeature ;
.
sysml:OutFlow
  rdf:type sysml:FlowDirection ;
  dc:description "Indicates that the flow property is an output of the owning Block." ;
  dtype:code 2 ;
  dtype:value "out"^^xsd:string ;
  rdfs:label "Out Flow"^^xsd:string ;
.
sysml:OutboundFlowProperty
  rdf:type owl:Class ;
  dc:description "A kind of \"Flow Property\"."^^xsd:string ;
  rdfs:label "Outbound Flow Property"^^xsd:string ;
  rdfs:subClassOf sysml:FlowProperty ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysml:OutFlow ;
      owl:onProperty sysmo:hasDirection ;
    ] ;
  owl:disjointWith sysml:InboundFlowProperty ;
.
sysml:ParticipantProperty
  rdf:type owl:Class ;
  dc:description "To refer to linked objects and values of an instance of an association block, it is necessary for the modeler to specify which (participant) properties of the association block identify the instances being linked at which end of the association. The value of a participant property on an instance (link) of the association block is the value or object at the end of the link corresponding to this end of the association. Participant properties can be the ends of connectors owned by an association block. The association block can be the type of multiple other connectors to reuse the same internal structure for all the connectors. The keyword \"participant\" before a property name indicates the property is stereotyped by ParticipantProperty. The types of participant properties can be elided if desired. They are always the same as the corresponding association end type." ;
  rdfs:label "Participant Property"^^xsd:string ;
  rdfs:subClassOf sysml:Property ;
.
sysml:PassVerdict
  rdf:type sysml:VerdictKind ;
  dtype:value "pass"^^xsd:string ;
  rdfs:label "Pass verdict"^^xsd:string ;
.
sysml:Port
  rdf:type owl:Class ;
  dc:description "A port is an interaction point between a block or part and its environment that is connected with other ports via connectors. The main motivation for specifying such ports on system elements is to allow the design of modular reusable blocks, with clearly defined interfaces. (Note: the block owns its ports and therefore the port is part of the blocks definition)." ;
  rdfs:label "Port"^^xsd:string ;
  rdfs:subClassOf sysml:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Block ;
      owl:onProperty sysmo:isPortOf ;
    ] ;
.
sysml:Property
  rdf:type owl:Class ;
  rdfs:label "Property"^^xsd:string ;
  rdfs:subClassOf sysml:Thing ;
.
sysml:PropertyFlowPort
  rdf:type owl:Class ;
  dc:description "A kind of \"Flow Port\"."^^xsd:string ;
  rdfs:label "Property Flow Port"^^xsd:string ;
  rdfs:subClassOf sysml:FlowPort ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:InboundFlowProperty ;
      owl:onProperty sysmo:hasInboundFlow ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:OutboundFlowProperty ;
      owl:onProperty sysmo:hasOutboundFlow ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:minCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasInboundFlow ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:minCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasOutboundFlow ;
    ] ;
.
sysml:Requirement
  rdf:type owl:Class ;
  rdfs:label "Requirement"^^xsd:string ;
  rdfs:subClassOf sysml:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Requirement ;
      owl:onProperty sysmo:hasTracedTo ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Requirement ;
      owl:onProperty sysmo:isDerivedFrom ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Requirement ;
      owl:onProperty sysmo:isRefinedBy ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysml:Requirement ;
      owl:onProperty sysmo:isVerifiedBy ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:text ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:id ;
    ] ;
.
sysml:RiskKind
  rdf:type owl:Class ;
  dc:description "1) High indicates an unacceptable level of risk, 2) Medium indicates an acceptable level of risk, and 3) Low indicates a minimal level of risk or no risk"^^xsd:string ;
  rdfs:label "Risk kind"^^xsd:string ;
  rdfs:subClassOf sysml:EnumeratedValue ;
.
sysml:TestVerificationKind
  rdf:type sysml:VerificationKind ;
  dc:description "Test indicates that verification will be performed through systematic exercising of the applicable item under appropriate conditions with instrumentation to measure required parameters and the collection, analysis, and evaluation of quantitative data to show that measured parameters equal or exceed specified requirements"^^xsd:string ;
  rdfs:label "Test verification kind"^^xsd:string ;
.
sysml:Thing
  rdf:type owl:Class ;
  rdfs:label "Thing"^^xsd:string ;
  rdfs:subClassOf owl:Thing ;
.
sysml:VerdictKind
  rdf:type owl:Class ;
  dc:description "Type of a return parameter of a TestCase must be VerdictKind, consistent with the UML Testing Profile."^^xsd:string ;
  rdfs:label "Verdict kind"^^xsd:string ;
  rdfs:subClassOf sysml:EnumeratedValue ;
.
sysml:VerdictKindEnumeration
  rdf:type sysml:Enumeration ;
  sysmo:element sysml:ErrorVerdict ;
  sysmo:element sysml:FailVerdict ;
  sysmo:element sysml:InconclusiveVerdict ;
  sysmo:element sysml:PassVerdict ;
  rdfs:label "Verdict kind enumeration"^^xsd:string ;
.
sysml:VerificationKind
  rdf:type owl:Class ;
  dc:description "An enumeraiton of the approaches to verification: anaylsis, demonstration, inspection and test. "^^xsd:string ;
  rdfs:label "Verification kind"^^xsd:string ;
  rdfs:subClassOf sysml:EnumeratedValue ;
.
sysml:hasBlock
  rdf:type owl:ObjectProperty ;
  rdf:type owl:TransitiveProperty ;
  rdfs:label "has block"^^xsd:string ;
  rdfs:subPropertyOf sysmo:hasPart ;
.
sysml:isBlockOf
  rdf:type owl:ObjectProperty ;
  rdfs:label "is block of"^^xsd:string ;
  rdfs:subPropertyOf sysmo:isPartOf ;
.
sysml:isEncapsulated
  rdf:type owl:DatatypeProperty ;
  rdfs:label "is encapsulated"^^xsd:string ;
  rdfs:range xsd:boolean ;
.
sysml:isHazardous
  rdf:type owl:DatatypeProperty ;
  dc:description "Indicates whether the command is hazardous."^^xsd:string ;
  rdfs:label "Is Hazardous"^^xsd:string ;
  rdfs:range xsd:boolean ;
.
sysmo:AC_AMBER
  rdf:type sysmo:AlarmColor ;
  rdf:type sysmo:ModalCue ;
.
sysmo:AC_GREEN
  rdf:type sysmo:AlarmColor ;
  rdf:type sysmo:ModalCue ;
.
sysmo:AC_ORANGE
  rdf:type sysmo:AlarmColor ;
  rdf:type sysmo:ModalCue ;
.
sysmo:AC_RED
  rdf:type sysmo:AlarmColor ;
  rdf:type sysmo:ModalCue ;
.
sysmo:AC_YELLOW
  rdf:type sysmo:AlarmColor ;
  rdf:type sysmo:ModalCue ;
.
sysmo:AT_ADVISORY
  rdf:type sysmo:AlarmType ;
  rdf:type sysmo:EnumeratedValue ;
  sysmo:hasModalCue sysmo:AC_YELLOW ;
  sysmo:hasModalCue sysmo:AuC_ADVISORY ;
  dtype:code 1 ;
  dtype:displayName "A"^^xsd:string ;
  dtype:order "1"^^xsd:nonNegativeInteger ;
  dtype:value "advisory"^^xsd:string ;
  rdfs:label "Advisory alarm type"^^xsd:string ;
.
sysmo:AT_CAUTION
  rdf:type sysmo:AlarmType ;
  rdf:type sysmo:EnumeratedValue ;
  sysmo:hasModalCue sysmo:AC_AMBER ;
  sysmo:hasModalCue sysmo:AuC_CAUTION ;
  dtype:code 2 ;
  dtype:displayName "C"^^xsd:string ;
  dtype:order "2"^^xsd:nonNegativeInteger ;
  dtype:value "caution"^^xsd:string ;
  rdfs:label "Caution alarm type"^^xsd:string ;
.
sysmo:AT_CHANGE
  rdf:type sysmo:AlarmType ;
  rdf:type sysmo:EnumeratedValue ;
  dtype:code 5 ;
  dtype:displayName "C"^^xsd:string ;
  dtype:order "5"^^xsd:nonNegativeInteger ;
  dtype:value "change"^^xsd:string ;
  rdfs:label "Change alarm type"^^xsd:string ;
.
sysmo:AT_EMERGENCY
  rdf:type sysmo:AlarmType ;
  rdf:type sysmo:EnumeratedValue ;
  sysmo:hasModalCue sysmo:AC_RED ;
  sysmo:hasModalCue sysmo:AuC_EMERGENCY ;
  dtype:code 4 ;
  dtype:displayName "E"^^xsd:string ;
  dtype:order "4"^^xsd:nonNegativeInteger ;
  dtype:value "emergency"^^xsd:string ;
  rdfs:label "Emergency alarm type"^^xsd:string ;
.
sysmo:AT_WARNING
  rdf:type sysmo:AlarmType ;
  sysmo:hasModalCue sysmo:AC_ORANGE ;
  sysmo:hasModalCue sysmo:AuC_WARNING ;
  dtype:code 3 ;
  dtype:displayName "W"^^xsd:string ;
  dtype:order "3"^^xsd:nonNegativeInteger ;
  dtype:value "warning"^^xsd:string ;
  rdfs:label "Warning alarm type"^^xsd:string ;
.
sysmo:AbnormalCondition
  rdf:type owl:Class ;
  rdfs:label "Abnormal condition"^^xsd:string ;
  rdfs:subClassOf sysmo:Condition ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:IncidentCondition ;
      owl:onProperty sysmo:indicates ;
    ] ;
.
sysmo:Actuator
  rdf:type owl:Class ;
  dc:description "A kind of \"Device\"."^^xsd:string ;
  rdfs:label "Actuator"^^xsd:string ;
  rdfs:subClassOf sysmo:Device ;
  owl:equivalentClass sysmo:Effector ;
.
sysmo:AdvisoryAlarm
  rdf:type owl:Class ;
  dc:description "Anomalous conditions in which a system or operations capability is degraded, but does not directly affect the crew or mission."^^xsd:string ;
  rdfs:label "Advisory alarm"^^xsd:string ;
  rdfs:subClassOf sysmo:Alarm ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysmo:AT_ADVISORY ;
      owl:onProperty sysmo:hasAlarmType ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue "1"^^xsd:int ;
      owl:onProperty dtype:code ;
    ] ;
  owl:equivalentClass [
      rdf:type owl:Class ;
      owl:intersectionOf (
          sysmo:Alarm
          [
            rdf:type owl:Restriction ;
            owl:hasValue sysmo:AT_ADVISORY ;
            owl:onProperty sysmo:hasAlarmType ;
          ]
        ) ;
    ] ;
.
sysmo:AdvisoryAlarmHighLimit
  rdf:type owl:Class ;
  dc:description "An anomalous condition in which a system or operations capability is degraded, but does not directly affect the crew or mission."^^xsd:string ;
  rdfs:label "Advisory alarm high limit"^^xsd:string ;
  rdfs:subClassOf sysmo:HighAlarmLimit ;
  owl:disjointWith sysmo:AdvisoryAlarmLowLimit ;
.
sysmo:AdvisoryAlarmLimitsPair
  rdf:type owl:Class ;
  rdfs:label "Advisory alarm limits pair"^^xsd:string ;
  rdfs:subClassOf sysmo:AlarmLimitsPair ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasAdvisoryAlarmHighLimit ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasAdvisoryAlarmLowLimit ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysmo:AT_ADVISORY ;
      owl:onProperty sysmo:hasAlarmType ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:advisoryDwellTime ;
    ] ;
  owl:equivalentClass [
      rdf:type owl:Class ;
      owl:intersectionOf (
          sysmo:AlarmLimitsPair
          [
            rdf:type owl:Restriction ;
            owl:hasValue sysmo:AT_ADVISORY ;
            owl:onProperty sysmo:hasAlarmType ;
          ]
        ) ;
    ] ;
.
sysmo:AdvisoryAlarmLimitsSpecification
  rdf:type owl:Class ;
  dc:description "High and Low Limits for an Advisory Alarm."^^xsd:string ;
  rdfs:label "Advisory Alarm Limits Specification"^^xsd:string ;
  rdfs:subClassOf sysmo:AlarmLimitsSpecification ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:AdvisoryAlarmHighLimit ;
      owl:onProperty sysmo:hasAlarmHighLimit ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:AdvisoryAlarmLowLimit ;
      owl:onProperty sysmo:hasAlarmLowLimit ;
    ] ;
.
sysmo:AdvisoryAlarmLowLimit
  rdf:type owl:Class ;
  dc:description "An anomalous condition in which a system or operations capability is degraded, but does not directly affect the crew or mission."^^xsd:string ;
  rdfs:label "Advisory alarm low limit"^^xsd:string ;
  rdfs:subClassOf sysmo:LowAlarmLimit ;
.
