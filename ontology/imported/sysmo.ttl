  rdfs:label "emergency dwell time"^^xsd:string ;
  rdfs:range xsd:double ;
  rdfs:subPropertyOf sysmo:dwellTime ;
.
sysmo:encodedValueLimits
  rdf:type owl:DatatypeProperty ;
  dc:description "Indicates whether the Low Limit and High Limit values are defined with respect to the encoded value or the engineering unit value. For calibrated parameters, this attribute is needed to determine whether the comparison is to be made before or after calibration. For non-calibrated parameters, there is no distinction and the field is not applicable. Must be one of the following: True â€“ limit values are with respect to the encoded value, if applicable; False â€“ limit values are with respect to the engineering unit value. If not specified, the value is assumed to be False." ;
  rdfs:label "encoded value limits"^^xsd:string ;
  rdfs:range xsd:boolean ;
.
sysmo:exclusiveLimit
  rdf:type sysmo:LimitType ;
  dtype:code 1 ;
  dtype:value "exclusive"^^xsd:string ;
  rdfs:label "exclusive limit"^^xsd:string ;
.
