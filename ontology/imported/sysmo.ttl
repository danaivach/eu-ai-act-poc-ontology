      owl:onProperty <http://www.sysmo.org/ontologies/spatial.owl#within> ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom <http://www.sysmo.org/ontologies/device.owl#SensorType> ;
