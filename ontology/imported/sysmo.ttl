  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:QuantifiedGoal ;
      owl:onProperty sysmo:hasQuantifiedGoal ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:StructuralFeature ;
      owl:onProperty sysmo:hasStructuralFeature ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
      owl:onProperty sysmo:hasSubsystem ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
      owl:onProperty sysmo:hasSubsystem ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:SystemType ;
      owl:onProperty sysmo:hasSystemType ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasCurrentCondition ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasCurrentMode ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasSystemType ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:occurence ;
    ] ;
.
sysmo:SystemGroup
  rdf:type owl:Class ;
  rdfs:label "System group"^^xsd:string ;
  rdfs:subClassOf sysmo:IdentifiableConcept ;
.
sysmo:SystemModeEnumeration
  rdf:type sysmo:TaggedEnumerationType ;
  sysmo:element sysmo:MODE_ANOMALY ;
  sysmo:element sysmo:MODE_COLD-START ;
  sysmo:element sysmo:MODE_DEGRADED ;
  sysmo:element sysmo:MODE_FAILED ;
  sysmo:element sysmo:MODE_HOT-START ;
  sysmo:element sysmo:MODE_NORMAL ;
  sysmo:element sysmo:MODE_RECON ;
  sysmo:element sysmo:MODE_RECOVERY ;
  sysmo:element sysmo:MODE_SAFED ;
  sysmo:element sysmo:MODE_SHUTDOWN ;
  sysmo:element sysmo:MODE_STANDBY ;
  sysmo:element sysmo:MODE_TEST ;
  sysmo:element sysmo:MODE_WARM-START ;
  rdfs:label "System mode enumeration"^^xsd:string ;
.
sysmo:SystemRoleQualifier
  rdf:type owl:Class ;
  dc:description "A kind of \"Thing\" with the following instance(s): \"Auxiliary\", \"Main\", \"Primary\", \"Secondary\", \"Standby\"."^^xsd:string ;
  rdfs:label "System Role Qualifier"^^xsd:string ;
  rdfs:subClassOf sysmo:EnumeratedValue ;
.
sysmo:SystemType
  rdf:type owl:Class ;
  dc:description "A classification of systems based on function, such as Mission Operations, Ground Operations, etc. as well as general systems categories such as IT, vehicles, devices, etc. A separate hierarchy of functions is defined for further classification of systems."^^xsd:string ;
  rdfs:label "System Type"^^xsd:string ;
  rdfs:subClassOf sysmo:EnumeratedValue ;
.
sysmo:TelecommandedParameter
  rdf:type owl:Class ;
  rdfs:label "Telecommanded Parameter"^^xsd:string ;
  rdfs:subClassOf sysmo:ControlledParameter ;
.
sysmo:TelemeteredProperty
  rdf:type owl:Class ;
  dc:description "A parameter of some system, component or device that is monitored over telemetry."^^xsd:string ;
  rdfs:label "Telemetered Property"^^xsd:string ;
  rdfs:subClassOf sysmo:MeasuredParameter ;
.
sysmo:Thing
  rdf:type owl:Class ;
  rdfs:label "Thing"^^xsd:string ;
  rdfs:subClassOf owl:Thing ;
.
sysmo:UnIntendedBehavior
  rdf:type owl:Class ;
  dc:description "A kind of \"Behavior Feature\"."^^xsd:string ;
  rdfs:label "Un Intended Behavior"^^xsd:string ;
  rdfs:subClassOf sysmo:BehaviorFeature ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue "false"^^xsd:boolean ;
      owl:onProperty sysmo:intentional ;
