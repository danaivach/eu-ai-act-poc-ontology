sysmo:systemID
  rdf:type owl:DatatypeProperty ;
  rdfs:range xsd:string ;
  rdfs:subPropertyOf sysmo:identifier ;
.
sysmo:triggerCount
  rdf:type owl:DatatypeProperty ;
  dc:description "The number of consecutive samples that the alarm condition needs to persist before an alarm is generated."^^xsd:string ;
  rdfs:label "trigger count"^^xsd:string ;
  rdfs:range xsd:nonNegativeInteger ;
.
sysmo:uses
  rdf:type owl:ObjectProperty ;
  rdfs:label "uses"^^xsd:string ;
.
sysmo:usesSystem
  rdf:type owl:ObjectProperty ;
  rdfs:label "uses system"^^xsd:string ;
  rdfs:subPropertyOf sysmo:uses ;
  owl:inverseOf sysmo:IsSystemUsedBy ;
.
sysmo:version
  rdf:type owl:DatatypeProperty ;
  dc:description "A version string constructed according to version encoding rules." ;
  rdfs:label "version"^^xsd:string ;
  rdfs:range xsd:string ;
.
sysmo:warningDwellTime
  rdf:type owl:DatatypeProperty ;
  dc:description "The time (in seconds expressed as double precision floating point) that the condition needs to persist before a warning alarm is generated." ;
  rdfs:label "warning dwell time"^^xsd:string ;
  rdfs:range xsd:double ;
  rdfs:subPropertyOf sysmo:dwellTime ;
.
prov:wasInfluencedBy
  rdf:type rdf:Property ;
.
