  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom <http://www.sysmo.org/ontologies/sysmo.owl#Value> ;
      owl:onProperty sysmo:requiresValue ;
    ] ;
.
sysmo:FunctionFeature
  rdf:type owl:Class ;
  dc:description "The notion of 'FunctionFeature' can be compared to the SysML notion of an 'Operations Block'." ;
  rdfs:label "Operational Feature"^^xsd:string ;
  rdfs:subClassOf sysml:Block ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:Capability ;
      owl:onProperty sysmo:realizes ;
    ] ;
.
sysmo:FunctionType
  rdf:type owl:Class ;
  rdfs:label "Function type"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:FunctionType ;
      owl:onProperty sysmo:subCategory ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:FunctionType ;
      owl:onProperty sysmo:subCategoryOf ;
    ] ;
.
sysmo:HabitatSystemType
  rdf:type owl:Class ;
  rdfs:label "Habitat system type"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
.
sysmo:HighAlarmLimit
  rdf:type owl:Class ;
  dc:description "A high alarm limit is a value which when transgressed will cause an alarm will be generated."^^xsd:string ;
  rdfs:label "High alarm limit"^^xsd:string ;
  rdfs:subClassOf sysmo:AlarmLimit ;
  owl:disjointWith sysmo:LowAlarmLimit ;
.
sysmo:IconicCueEnumeration
  rdf:type owl:Class ;
  rdfs:label "Iconic cue enumeration"^^xsd:string ;
  rdfs:subClassOf sysmo:ModalCueEnumeration ;
.
sysmo:IdentifiableConcept
  rdf:type owl:Class ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:sid ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:cui ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:version ;
    ] ;
.
sysmo:Identifier
  rdf:type owl:Class ;
  dc:description "A kind of \"Identifier\"."^^xsd:string ;
  rdfs:label "Identifier"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
.
sysmo:IncidentCondition
  rdf:type owl:Class ;
  dc:description "A kind of \"Condition\"."^^xsd:string ;
  rdfs:label "Incident Condition"^^xsd:string ;
  rdfs:subClassOf sysmo:Condition ;
.
sysmo:IntendedBehavior
  rdf:type owl:Class ;
  dc:description "A kind of \"Behavior Feature\"."^^xsd:string ;
  rdfs:label "Intended Behavior"^^xsd:string ;
  rdfs:subClassOf sysmo:BehaviorFeature ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue "true"^^xsd:boolean ;
      owl:onProperty sysmo:intentional ;
    ] ;
  owl:disjointWith sysmo:UnIntendedBehavior ;
.
sysmo:Intent
  rdf:type owl:Class ;
  rdfs:label "Intent"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
.
sysmo:Interface
  rdf:type owl:Class ;
  rdfs:label "Interface"^^xsd:string ;
  rdfs:subClassOf sysmo:IdentifiableConcept ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:System ;
      owl:onProperty sysmo:interfacesWith ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom [
          rdf:type owl:Class ;
          owl:unionOf (
              sysmo:Operation
              sysmo:Signal
            ) ;
        ] ;
      owl:onProperty sysmo:specifies ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:minCardinality "2"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:interfacesWith ;
    ] ;
.
sysmo:InterfaceQualifier
  rdf:type owl:Class ;
  rdfs:label "Interface Qualifier"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
.
sysmo:IsSystemUsedBy
  rdf:type owl:ObjectProperty ;
  rdfs:label "system used by"^^xsd:string ;
  rdfs:subPropertyOf sysmo:isUsedBy ;
  owl:inverseOf sysmo:usesSystem ;
.
sysmo:ItemFlow
  rdf:type owl:Class ;
  dc:description "An Item Flow describes the flow of items across a connector or an association. It may constrain the item exchange between Blocks, Block usages or FlowPorts as specified by their FlowProperties. For example, a Pump connected to a Tank: the Pump has an out FlowProperty of type Liquid and the Tank has an in FlowProperty of type Liquid. To signify that only Water flow between the Pump and the Tank, we can specify an ItemFlow of type Water on the connector." ;
  rdfs:label "Item Flow"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
.
sysmo:KinestheticCueEnumeration
  rdf:type owl:Class ;
  rdfs:label "Kinesthetic cue enumeration"^^xsd:string ;
  rdfs:subClassOf sysmo:ModalCueEnumeration ;
.
sysmo:LimitType
  rdf:type owl:Class ;
  dc:description "Determines if the low and high limits are to be interpreted as the lower and upper bounds of valid or invalid data. If the Limit Type is Inclusive, then any value between the low and high limits is considered acceptable. Values below the low limit or above the high limit would be considered invalid. If the Limit Type is Exclusive, then any value between the low and high limits is considered unacceptable. Values below the low limit or above the high limit would be considered valid." ;
  rdfs:label "Limit Type"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
.
sysmo:Location
  rdf:type owl:Class ;
  dc:description "A descriptor for the location that something has within a system or vehicle." ;
  rdfs:label "Location"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:busID ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty <http://www.sysmo.org/ontologies/sysmo.owl#subsystemID> ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty <http://www.sysmo.org/ontologies/sysmo.owl#unitID> ;
    ] ;
.
sysmo:LowAlarmLimit
  rdf:type owl:Class ;
  dc:description "A \"Alarm limit\"."^^xsd:string ;
  rdfs:label "Low alarm limit"^^xsd:string ;
  rdfs:subClassOf sysmo:AlarmLimit ;
.
sysmo:MODE_ANOMALY
  rdf:type sysmo:Mode ;
  sysmo:description "An incident has occurred that indicates a possible failure"^^xsd:string ;
  dtype:code 10 ;
  dtype:description "An incident has occurred that indicates a possible failure"^^xsd:string ;
  dtype:value "anomaly"^^xsd:string ;
  rdfs:label "Anomaly mode"^^xsd:string ;
.
sysmo:MODE_COLD-START
  rdf:type sysmo:Mode ;
  sysmo:description "The system is in condition ready for a complete restart and needs configuration data"^^xsd:string ;
  dtype:code 3 ;
  dtype:description "The system is in condition ready for a complete restart and needs configuration data"^^xsd:string ;
  dtype:value "coldstart"^^xsd:string ;
  rdfs:label "Cold start mode"^^xsd:string ;
.
sysmo:MODE_DEGRADED
  rdf:type sysmo:Mode ;
  dtype:code 11 ;
  dtype:value "degraded"^^xsd:string ;
  rdfs:label "Degraded mode"^^xsd:string ;
.
sysmo:MODE_FAILED
  rdf:type sysmo:Mode ;
  dtype:code 15 ;
  dtype:value "failed"^^xsd:string ;
  rdfs:label "Failed mode"^^xsd:string ;
.
sysmo:MODE_HOT-START
  rdf:type sysmo:Mode ;
  dtype:code 5 ;
  dtype:value "hotstart"^^xsd:string ;
  rdfs:label "Hot start mode"^^xsd:string ;
.
sysmo:MODE_NORMAL
  rdf:type sysmo:Mode ;
  dtype:code 6 ;
  dtype:value "normal"^^xsd:string ;
  rdfs:label "Normal mode"^^xsd:string ;
.
sysmo:MODE_RECON
  rdf:type sysmo:Mode ;
  dtype:code 2 ;
  dtype:value "recon"^^xsd:string ;
  rdfs:label "Recon mode"^^xsd:string ;
.
sysmo:MODE_RECOVERY
  rdf:type sysmo:Mode ;
  dtype:code 9 ;
  dtype:value "recovery"^^xsd:string ;
  rdfs:label "Recovery mode"^^xsd:string ;
.
sysmo:MODE_SAFED
  rdf:type sysmo:Mode ;
  sysmo:description "The system is in a state for maintenance to be performed"^^xsd:string ;
  dtype:code 12 ;
  dtype:description "The system is in a state for maintenance to be performed"^^xsd:string ;
  dtype:value "safed"^^xsd:string ;
  rdfs:label "Safed mode"^^xsd:string ;
.
sysmo:MODE_SHUTDOWN
  rdf:type sysmo:Mode ;
  dtype:code 1 ;
  dtype:value "shutdown"^^xsd:string ;
  rdfs:label "Shut down mode"^^xsd:string ;
.
sysmo:MODE_STANDBY
  rdf:type sysmo:Mode ;
  dtype:code 7 ;
  dtype:value "standby"^^xsd:string ;
  rdfs:label "Standby mode"^^xsd:string ;
.
sysmo:MODE_TEST
  rdf:type sysmo:Mode ;
  dtype:code 8 ;
  dtype:value "test"^^xsd:string ;
  rdfs:label "Test mode"^^xsd:string ;
.
sysmo:MODE_WARM-START
  rdf:type sysmo:Mode ;
  dtype:code 4 ;
  dtype:value "warmstart"^^xsd:string ;
  rdfs:label "Warm start mode"^^xsd:string ;
.
