  rdfs:subClassOf sysmo:Element ;
  rdfs:subClassOf sysmo:System ;
.
sysmo:AuC_ADVISORY
  rdf:type sysmo:AuralCue ;
  rdf:type sysmo:ModalCue ;
  dtype:code "1"^^xsd:nonNegativeInteger ;
