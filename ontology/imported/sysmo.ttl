sysmo:View
  rdf:type owl:Class ;
  dc:description "A view is a representation of a system or subsystem from the perspective of a single viewpoint." ;
  rdfs:label "View"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      dc:description """the conform relationship is a dependency between the view and a viewpoint. The view conforms to the specified rules and
conventions detailed in the viewpoint.""" ;
      owl:allValuesFrom sysmo:ViewPoint ;
      owl:onProperty sysmo:conformsTo ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onProperty sysmo:conformsTo ;
    ] ;
.
sysmo:ViewPoint
  rdf:type owl:Class ;
  dc:description "A viewpoint is a specification of the conventions and rules for constructing and using a view for the purpose of addressing a set of stakeholder concerns. The languages and methods for specifying a view may reference methods and languages in another viewpoint. They specify the elements expected to be represented in the view, and may be formally or informally defined. For example, the security viewpoint may require the security requirements, security functional and physical architecture, and security test cases." ;
  rdfs:label "View Point"^^xsd:string ;
  rdfs:subClassOf sysmo:Thing ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:description ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:purpose ;
    ] ;
.
sysmo:VisibilityKind
  rdf:type owl:Class ;
  rdfs:label "Visibility kind"^^xsd:string ;
  rdfs:subClassOf sysmo:EnumeratedValue ;
.
sysmo:VisibilityKindEnumeration
  rdf:type sysmo:TaggedEnumerationType ;
  dc:description "VisibilityKind is an enumeration of the following literal values: 'public', 'private' and 'protected'."^^xsd:string ;
  rdfs:label "Visibility kind enumeration"^^xsd:string ;
.
sysmo:VisualCueEnumeration
  rdf:type owl:Class ;
  rdfs:label "Visual cue enumeration"^^xsd:string ;
  rdfs:subClassOf sysmo:ModalCueEnumeration ;
.
sysmo:WarningAlarm
  rdf:type owl:Class ;
  dc:description "Conditions that require immediate correction to avoid loss of major impact to mission or potential loss of crew. Included are faults, failures, and out of tolerance conditions for functions critical to Constellation System survival and crew survival."^^xsd:string ;
  rdfs:label "Warning alarm"^^xsd:string ;
  rdfs:subClassOf sysmo:Alarm ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue sysmo:AT_CAUTION ;
      owl:onProperty sysmo:hasAlarmType ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:hasValue "3"^^xsd:int ;
      owl:onProperty dtype:code ;
    ] ;
  owl:equivalentClass [
      rdf:type owl:Class ;
      owl:intersectionOf (
          sysmo:Alarm
          [
            rdf:type owl:Restriction ;
            owl:hasValue sysmo:AT_CAUTION ;
            owl:onProperty sysmo:hasAlarmType ;
          ]
        ) ;
    ] ;
.
sysmo:WarningAlarmHighLimit
  rdf:type owl:Class ;
  dc:description "Conditions that require immediate correction to avoid loss of major impact to mission or potential loss of crew. Included are faults, failures, and out of tolerance conditions for functions critical to Constellation System survival and crew survival."^^xsd:string ;
  rdfs:label "Warning alarm high limit"^^xsd:string ;
  rdfs:subClassOf sysmo:CautionaryAlarmHighLimit ;
  owl:disjointWith sysmo:WarningAlarmLowLimit ;
.
sysmo:WarningAlarmLimitsPair
  rdf:type owl:Class ;
  rdfs:label "Warning alarm limits pair"^^xsd:string ;
  rdfs:subClassOf sysmo:AlarmLimitsPair ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasWarningAlarmHighLimit ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:cardinality "1"^^xsd:int ;
      owl:onProperty sysmo:hasWarningAlarmLowLimit ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:maxCardinality "1"^^xsd:int ;
      owl:onProperty sysmo:warningDwellTime ;
    ] ;
.
sysmo:WarningAlarmLimitsSpecification
  rdf:type owl:Class ;
  dc:description "High and Low Limits for an Advisory Alarm."^^xsd:string ;
  rdfs:label "Warning Alarm Limits Specification."^^xsd:string ;
  rdfs:subClassOf sysmo:AlarmLimitsSpecification ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:WarningAlarmHighLimit ;
      owl:onProperty sysmo:hasAlarmHighLimit ;
    ] ;
  rdfs:subClassOf [
      rdf:type owl:Restriction ;
      owl:allValuesFrom sysmo:WarningAlarmLowLimit ;
      owl:onProperty sysmo:hasAlarmLowLimit ;
    ] ;
.
sysmo:WarningAlarmLowLimit
  rdf:type owl:Class ;
